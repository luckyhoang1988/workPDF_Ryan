{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RyanPDF",
  "mainBinaryName": "RyanPDF",
  "version": "2.14.1",
  "identifier": "com.ryanpdf.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite --mode desktop",
    "beforeBuildCommand": "npx vite build --mode desktop"
  },
  "app": {
    "windows": [
      {
        "title": "RyanPDF",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "additionalBrowserArgs": "--enable-features=CertVerifierBuiltinFeature"
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "RyanPDF Inc.",
    "targets": ["deb", "rpm", "appimage", "dmg", "app", "msi"],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/192x192.png"
    ],
    "resources": ["libs/*.jar", "runtime/jre/**/*"],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "role": "Editor",
        "mimeType": "application/pdf"
      }
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "ryanpdf.desktop"
      },
      "rpm": {
        "desktopTemplate": "ryanpdf.desktop",
        "compression": { "type": "zstd", "level": 3 }
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "upgradeCode": "3305fba9-7e5e-5c09-bc71-eca0a65f4fee",
        "bannerPath": "windows/wix/banner.bmp",
        "dialogImagePath": "windows/wix/dialog.bmp",
        "fragmentPaths": ["windows/wix/provisioning.wxs"],
        "componentGroupRefs": ["ProvisioningComponentGroup"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null,
      "providerShortName": null,
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "deep-link": {
      "desktop": {
        "schemes": ["ryanpdf"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/luckyhoang1988/workPDF_Ryan/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1MjFDOTg1OTE0MzE4NjQKUldSa0dFT1JoY2toVlFrSWpFYmVJWURBWlJzbldENWRabkVUUkNhTDVJSW1VYkhVU215V3BucjYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
