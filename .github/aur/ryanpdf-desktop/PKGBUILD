# Maintainer: RyanPDF Inc <hoangtruonghd88@gmail.com>
pkgname=ryanpdf-desktop
pkgver=2.14.1
pkgrel=1
pkgdesc="Locally hosted, web-based PDF manipulation tool (Tauri desktop app, official RyanPDF build)"
arch=('x86_64')
url="https://github.com/luckyhoang1988/workPDF_Ryan"
license=('MIT')
depends=('gtk3' 'webkit2gtk-4.1' 'libappindicator-gtk3')
provides=('ryanpdf')
conflicts=('ryanpdf' 'ryanpdf-git' 'ryanpdf-bin')
options=('!strip')

source_x86_64=("${pkgname}-${pkgver}.deb::https://github.com/luckyhoang1988/workPDF_Ryan/releases/download/v${pkgver}/RyanPDF-linux-x86_64.deb")
sha256sums_x86_64=('PLACEHOLDER_DEB_SHA256')

package() {
    # Extract the .deb archive
    bsdtar -xf data.tar* -C "${pkgdir}"

    # Fix permissions
    find "${pkgdir}" -type d -exec chmod 755 {} \;

    # Install license
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" <<EOF
MIT License

Copyright (c) 2025 RyanPDF Inc
See https://github.com/luckyhoang1988/workPDF_Ryan/blob/main/LICENSE
EOF
}
